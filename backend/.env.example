# Backend Environment Variables
# Copy to .env and fill in real values

PORT=5000
NODE_ENV=development

# Firebase Admin (mock for now)
FIREBASE_PROJECT_ID=cargohub
FIREBASE_PRIVATE_KEY="mock-key"
FIREBASE_CLIENT_EMAIL=mock@cargohub.iam.gserviceaccount.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis (Upstash)
REDIS_URL=redis://localhost:6379

# Razorpay
RAZORPAY_KEY_ID=rzp_test_mock
RAZORPAY_KEY_SECRET=mock_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=far-away
CLOUDINARY_API_KEY=mock
CLOUDINARY_API_SECRET=mock

# CORS
WEBSITE_URL=http://localhost:3000
WEBSITE_URL_LOCAL=http://localhost:3000

# Mapbox
MAPBOX_ACCESS_TOKEN=pk.mock
