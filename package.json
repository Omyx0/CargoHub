{
  "name": "cargohub",
  "version": "1.0.0",
  "private": true,
  "description": "CargoHub — Cross-platform cargo logistics platform",
  "workspaces": [
    "frontend",
    "backend",
    "backend/src/shared",
    "mobile-app/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:web\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:web": "npm run dev --workspace=frontend",
    "dev:driver": "npm run start --workspace=driver-app",
    "dev:mobile-customer": "npm run start --workspace=customer-app",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "expo": "~52.0.25",
    "expo-asset": "~11.0.5",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "react-native": "0.76.9",
    "@types/react": "~18.3.12",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "expo": "~52.0.25"
  }
}
