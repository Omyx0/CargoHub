{
  "name": "cargohub",
  "version": "1.0.0",
  "private": true,
  "description": "CargoHub — Cross-platform cargo logistics platform",
  "workspaces": [
    "shared",
    "backend",
    "website"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:website": "npm run dev --workspace=website",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:website\"",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
